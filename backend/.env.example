# ──────────────────────────────────────────────────────────────────────────────
# Crabby's Mission Control — Backend Environment
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is gitignored. .env.example is tracked in git.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenClaw gateway ──────────────────────────────────────────────────────────
# URL of the running OpenClaw gateway process (default is fine for local setup)
OPENCLAW_GATEWAY_URL=http://localhost:18789

# Authentication token for the OpenClaw gateway.
# Find yours in ~/.openclaw/config.yml or the OpenClaw dashboard.
# REQUIRED — leave blank and gateway calls will be made without auth.
OPENCLAW_GATEWAY_TOKEN=your_token_here

# ── OpenClaw workspace ────────────────────────────────────────────────────────
# Root directory OpenClaw uses for files, memory, and workspace docs.
# Uncomment and change only if your setup differs from the default.
# OPENCLAW_HOME=/Users/yourname/.openclaw

# ── Security ──────────────────────────────────────────────────────────────────
# Keep this as 127.0.0.1 to prevent the Rails API from binding to a public
# interface. Only change if you are intentionally exposing the app on a LAN
# (e.g. behind Tailscale).
RAILS_BIND=127.0.0.1

# Shared secret for authenticating inbound webhook calls from OpenClaw agents.
# If set, all POST /api/v1/openclaw/webhook requests must include the header:
#   X-Mission-Control-Token: <this value>
# If blank, webhooks are accepted without authentication (localhost-only mode).
# STRONGLY recommended in production or any non-localhost deployment.
MISSION_CONTROL_WEBHOOK_TOKEN=
